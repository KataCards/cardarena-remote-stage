# Chromium Kiosk Browser Configuration
# Copy this file to .env and customize as needed

# Browser Settings
BROWSER_TYPE=chromium
HEADLESS=false

# Kiosk Mode
KIOSK_MODE=true
START_URL=https://www.example.com

# Display Settings
WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080

# URL Rotation (for digital signage)
ENABLE_ROTATION=false
ROTATION_URLS=https://www.google.com,https://www.github.com,https://www.wikipedia.org
ROTATION_INTERVAL=30

# Browser Features
DISABLE_INFOBARS=true
DISABLE_NOTIFICATIONS=true
DISABLE_SESSION_RESTORE=true

# Performance (useful for Raspberry Pi / embedded systems)
DISABLE_GPU=false
DISABLE_DEV_SHM=false

# Timeouts (in milliseconds)
PAGE_LOAD_TIMEOUT=30000
NAVIGATION_TIMEOUT=30000

# Error Handling
AUTO_RESTART_ON_CRASH=true
MAX_RESTART_ATTEMPTS=3

# Logging
LOG_LEVEL=INFO
ENABLE_CONSOLE_LOGGING=true