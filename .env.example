# Network binding
HOST=0.0.0.0
PORT=8000

# Logging
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# LOG_FORMAT: json (structured, for log aggregators), console (human-readable)
LOG_FORMAT=json

# Security
# Supported values: api_key, ip_whitelist
SECURITY_PROVIDER=api_key

# API key provider settings
APIKEY_DB_PATH=./security.db
APIKEY_DB_TYPE=sqlite
# Required when SECURITY_PROVIDER=api_key. Set before first run.
# Generate with: openssl rand -hex 32
APIKEY_SECRET=

# IP whitelist provider settings
# Comma-separated list, for example: 127.0.0.1,10.0.0.5
ALLOWED_IPS=

# Kiosk settings
# Supports https://, http://, file://, or a relative path (resolved from project root)
KIOSK_DEFAULT_URL=https://example.com
KIOSK_NAME=default
# Playwright browser engine: chromium, firefox, webkit
KIOSK_PLAYWRIGHT_BROWSER_TYPE=chromium
KIOSK_HEADLESS=false
KIOSK_FULLSCREEN=false
# Optional extra Playwright launch args, space-separated (shell quoting supported)
# Example: --window-size=1920,1080 --incognito
KIOSK_PLAYWRIGHT_LAUNCH_ARGS=
# Comma-separated list, for example: https://example.com,https://status.example.com
KIOSK_ALLOWED_URLS=
# Maximum number of activity events retained per kiosk (ring buffer)
KIOSK_HISTORY_SIZE=100

# Error page routing
# Set KIOSK_ERROR_PAGES_DIR to a folder structured as: <status_code>/index.html (e.g. 404/index.html)
# Set KIOSK_ERROR_ROUTING=false to disable error page interception entirely
KIOSK_ERROR_ROUTING=true
KIOSK_ERROR_PAGES_DIR=
